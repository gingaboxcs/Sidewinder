{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sidewinder",
  "version": "0.1.0",
  "identifier": "com.sidewinder.notes",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Sidewinder",
        "width": 30,
        "height": 700,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU3REVCRDg0MUFFMjQ3MkIKUldRclIrSWFoTDNlVjRtMTBCcUxxYVZIMko2RjhsVnJOdW1EWFdrcWpEMWdBTlNQd3BjZHZyWkgK",
      "endpoints": [
        "https://github.com/gingaboxcs/Sidewinder/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
